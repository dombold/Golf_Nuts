# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/golf_nuts?schema=public"

# NextAuth
NEXTAUTH_SECRET="change-me-to-a-random-32-char-secret"
NEXTAUTH_URL="http://localhost:3000"

# Golf Course API (add subscription key when ready)
GOLF_COURSE_API_KEY=""
GOLF_COURSE_API_BASE_URL="https://api.golfcourseapi.com/v1"

# Google Maps Static API (server-side only — do NOT use NEXT_PUBLIC prefix)
GOOGLE_MAPS_API_KEY=""

# Web Push (VAPID) — generate keys once:
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
# Use the same publicKey value for both VAPID_PUBLIC_KEY and NEXT_PUBLIC_VAPID_PUBLIC_KEY.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# Email (for password reset)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Golf Nuts <noreply@example.com>"
