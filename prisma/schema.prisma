generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(cuid())
  username       String   @unique
  firstName      String
  lastName       String
  name           String
  email          String   @unique
  passwordHash   String
  handicapIndex  Float    @default(0)
  avatarUrl      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  rounds                 RoundPlayer[]
  handicapHistory        HandicapHistory[]
  comments               Comment[]
  likes                  Like[]
  organisedTournaments   Tournament[]             @relation("OrganiserTournaments")
  tournamentInvitations  TournamentInvitation[]
  tournamentGroupMembers TournamentGroupMember[]

  @@map("users")
}

model Course {
  id        String   @id @default(cuid())
  name      String
  address   String?
  city      String?
  state     String?
  country   String?
  externalId String? @unique
  aliases    String[] @default([])
  createdAt DateTime @default(now())

  tees        Tee[]
  rounds      Round[]
  tournaments Tournament[]

  @@map("courses")
}

model Tee {
  id       String  @id @default(cuid())
  courseId String
  name     String
  color    String?
  rating   Float
  slope    Int
  par      Int

  course           Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  holes            Hole[]
  rounds           Round[]
  tournaments      Tournament[]
  tournamentGroups TournamentGroup[]

  @@unique([courseId, name])
  @@map("tees")
}

model Hole {
  id          String @id @default(cuid())
  teeId       String
  number      Int
  par         Int
  strokeIndex Int
  distance    Int?
  teeLat      Float?
  teeLng      Float?
  greenLat    Float?
  greenLng    Float?

  tee Tee @relation(fields: [teeId], references: [id], onDelete: Cascade)

  @@unique([teeId, number])
  @@map("holes")
}

enum GameFormat {
  STROKEPLAY
  STABLEFORD
  MATCH_PLAY
  SKINS
  AMBROSE_2
  AMBROSE_4
}

enum RoundStatus {
  SETUP
  ACTIVE
  COMPLETE
}

model Round {
  id        String      @id @default(cuid())
  courseId  String
  teeId     String
  date      DateTime    @default(now())
  format    GameFormat
  status    RoundStatus @default(SETUP)
  holesCount Int         @default(18)
  notes     String?
  createdAt DateTime    @default(now())

  course   Course        @relation(fields: [courseId], references: [id])
  tee      Tee           @relation(fields: [teeId], references: [id])
  players  RoundPlayer[]
  comments Comment[]
  likes    Like[]
  tournamentRounds TournamentRound[]

  @@map("rounds")
}

model RoundPlayer {
  id                   String  @id @default(cuid())
  roundId              String
  userId               String
  playingHandicap      Int     @default(0)
  teamColor            String?
  teamNumber           Int?
  excludeFromHandicap  Boolean @default(false)

  round  Round   @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id])
  scores Score[]

  @@unique([roundId, userId])
  @@map("round_players")
}

model Score {
  id            String  @id @default(cuid())
  roundPlayerId String
  holeNumber    Int
  strokes       Int
  penalties     Int     @default(0)
  putts         Int?
  fairwayHit    Boolean?
  gir           Boolean?

  roundPlayer RoundPlayer @relation(fields: [roundPlayerId], references: [id], onDelete: Cascade)

  @@unique([roundPlayerId, holeNumber])
  @@map("scores")
}

model HandicapHistory {
  id           String   @id @default(cuid())
  userId       String
  index        Float
  differential Float
  roundId      String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("handicap_history")
}

model Comment {
  id        String   @id @default(cuid())
  roundId   String
  userId    String
  body      String
  createdAt DateTime @default(now())

  round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@map("comments")
}

model Like {
  id      String @id @default(cuid())
  roundId String
  userId  String

  round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([roundId, userId])
  @@map("likes")
}

enum TournamentStatus {
  UPCOMING
  ACTIVE
  COMPLETE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Tournament {
  id          String           @id @default(cuid())
  name        String
  format      GameFormat
  status      TournamentStatus @default(UPCOMING)
  date        DateTime?
  createdAt   DateTime         @default(now())

  createdById String
  courseId    String?
  teeId       String?

  createdBy   User                   @relation("OrganiserTournaments", fields: [createdById], references: [id])
  course      Course?                @relation(fields: [courseId], references: [id])
  tee         Tee?                   @relation(fields: [teeId], references: [id])
  rounds      TournamentRound[]
  invitations TournamentInvitation[]
  groups      TournamentGroup[]

  @@map("tournaments")
}

model TournamentRound {
  id           String @id @default(cuid())
  tournamentId String
  roundId      String
  roundNumber  Int

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round      Round      @relation(fields: [roundId], references: [id])

  @@unique([tournamentId, roundNumber])
  @@map("tournament_rounds")
}

model TournamentInvitation {
  id           String           @id @default(cuid())
  tournamentId String
  userId       String
  status       InvitationStatus @default(PENDING)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@unique([tournamentId, userId])
  @@map("tournament_invitations")
}

model TournamentGroup {
  id           String @id @default(cuid())
  tournamentId String
  groupNumber  Int
  teeId        String

  tournament Tournament              @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tee        Tee                     @relation(fields: [teeId], references: [id])
  members    TournamentGroupMember[]

  @@unique([tournamentId, groupNumber])
  @@map("tournament_groups")
}

model TournamentGroupMember {
  id         String @id @default(cuid())
  groupId    String
  userId     String
  teamNumber Int?

  group TournamentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User            @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@map("tournament_group_members")
}
